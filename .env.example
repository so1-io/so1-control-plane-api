# so1-control-plane-api Environment Variables
# Copy this file to .env.local and fill in your values

# === Server Configuration ===
# Required: Server port (default: 3001)
PORT=3001

# Optional: Runtime environment (development|production, default: development)
NODE_ENV=development

# === Clerk Authentication ===
# CURRENTLY: Using mock token format (clerk_<userId>_<orgId>) in development
# 
# For local development, send Authorization header:
#   Authorization: Bearer clerk_user123_org456
#
# TODO: In production, these would be used for real Clerk backend verification
# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# === GitHub Integration ===
# TODO: Implemented in TASKSET 6
# Personal access token for GitHub API calls
# Scope: repo, public_repo (at minimum)
# GITHUB_TOKEN=ghp_...

# === n8n Integration ===
# TODO: Implemented in TASKSET 7
# API key and base URL for n8n instance
# N8N_API_KEY=...
# N8N_BASE_URL=https://n8n.example.com

# === Secrets Manager ===
# TODO: Implemented in TASKSET 5
# SECRETS_MANAGER_TYPE=dummy
# SECRETS_MANAGER_REGION=us-east-1

# === OpenTelemetry (Optional) ===
# For distributed tracing (not required for MVP)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_TRACE_ENABLED=false
