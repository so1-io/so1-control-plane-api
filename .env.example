# so1-control-plane-api Environment Variables
# Copy this file to .env.local and fill in your values

# === Server Configuration ===
PORT=3001
NODE_ENV=development

# === Clerk Configuration ===
# Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# === GitHub Configuration ===
# Personal access token for GitHub API calls
# Scope: repo, public_repo (at minimum)
GITHUB_TOKEN=ghp_...

# === n8n Configuration ===
# API key and base URL for n8n instance
N8N_API_KEY=...
N8N_BASE_URL=https://n8n.example.com

# === Secrets Manager Configuration ===
SECRETS_MANAGER_TYPE=dummy
SECRETS_MANAGER_REGION=us-east-1

# === OpenTelemetry Configuration ===
# (Optional, for distributed tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACE_ENABLED=false

# === Logging ===
LOG_LEVEL=debug
